# 本地 SQLite 数据库；不配置时默认使用项目下的 .data/bughub.sqlite
# BUGHUB_DATABASE_PATH=/absolute/path/to/bughub.sqlite

# 可选：调用 /api/revalidate 时使用 Authorization: Bearer <secret>
# REVALIDATE_SECRET=

# ---- 管理后台（独立域名 + 账号密码登录）----
# 后台访问域名，默认 admin.bughub.vip；仅该域名可访问后台
# ADMIN_HOST=admin.bughub.vip

# 管理员账号
# ADMIN_USERNAME=admin

# 管理员密码哈希（不要写明文）。用下面命令生成后粘贴：
#   npm run admin:hash-password -- '你的强密码'
# 生成结果形如 scrypt$<salt>$<key>
# ADMIN_PASSWORD_HASH=

# 会话签名密钥：至少 32 个字符的高强度随机串，可用 `openssl rand -base64 48` 生成
# ADMIN_SESSION_SECRET=

# 后台“预览公开页面”使用的主站地址，默认 https://bughub.vip
# PUBLIC_SITE_URL=https://bughub.vip
